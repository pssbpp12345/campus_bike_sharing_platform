# ──────────────────────────────────────────────────────────────
# Campus Bike Sharing — Backend Environment Variables
# Copy this file to `.env` and fill in your real values.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=campus_bike_sharing
PGUSER=postgres
PGPASSWORD=postgres

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# HTTP server port
PORT=8001
APP_BASE_URL=http://localhost:8001

# Google Maps JavaScript API (browser-side key)
# Restrict the key in Google Cloud Console by HTTP referrer:
#   http://localhost:*  http://localhost:8001/*  <your-deployed-domain>/*
GOOGLE_MAPS_API_KEY=

# Stripe — test mode for demo, live mode in production
# Put your secret keys in backend/.env only. Never commit them.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=aud
BOOKING_UNLOCK_FEE_CENTS=100
BOOKING_PER_MINUTE_CENTS=20

# Grace window (minutes) for manual Start Ride after a scheduled
# booking's start time. After this window the booking auto-expires.
READY_TO_START_GRACE_MINUTES=15

# Optional: OpenAI key for the admin AI assistant (Admin_ai page).
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────
# Contact form notifications (optional)
# Every contact submission is ALWAYS saved to the database.
# If SMTP_HOST is set we ALSO email ADMIN_EMAIL on each new message.
# Leave SMTP_HOST blank to disable outbound email entirely.
# ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@university.edu

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Campus Bike Sharing <noreply@university.edu>"
